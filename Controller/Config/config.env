# Configurazione Arduino Server

# Porta WebSocket del server
WEBSOCKET_PORT=8765

# Configurazione seriale Arduino
ARDUINO_BAUDRATE=9600
ARDUINO_TIMEOUT=1

# Auto-rilevamento porta Arduino (commentare se si vuole specificarla manualmente)
# ARDUINO_PORT=/dev/ttyUSB0
# ARDUINO_PORT=COM3

# Logging
LOG_LEVEL=INFO

# Riconnessione
RECONNECT_ATTEMPTS=10
RECONNECT_DELAY=2000
